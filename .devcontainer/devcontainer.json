{
  "name": "Cardano Node + Nix Dev",
  // "image": "cardano-node:10.6.1",
  "build": {
    "dockerfile": "../Dockerfile",
    "args": {}
  },

  "remoteUser": "root",


  "customizations": {
    // "vscode": {
      "settings": {
       "haskell.manageHLS": "PATH",
       "haskell.serverExecutablePath": "${workspaceFolder}/hls-nix.sh",
       "haskell.serverExtraArgs": "+RTS -M1500m -A32m -Iw60 -RTS",
       "haskell.plugin.ghcide-type-lenses.globalOn": false,
       "haskell.plugin.eval.globalOn": false,
       "haskell.plugin.retrie.globalOn": false,
       "haskell.plugin.tactics.globalOn": false,
       "haskell.plugin.hlint.globalOn": false,
       "haskell.plugin.stan.globalOn": false,
       "haskell.plugin.fourmolu.globalOn": false,
       "haskell.plugin.ghcide-completions.config.snippetsOn": false,
       "haskell.plugin.ghcide-completions.config.autoExtendOn": false,
       "haskell.maxCompletions": 40
      },
      "extensions": [
        "haskell.haskell",
        "ms-vscode.remote-containers",
        "ms-azuretools.vscode-docker",
        "jnoortheen.nix-ide"
      ]
    },
  

  "mounts": [
    "source=/mnt/c/Users/alberto/cardano/preview/config,target=/config,type=bind",
    "source=/mnt/c/Users/alberto/cardano/preview/db,target=/data/db,type=bind",
    "source=/mnt/c/Users/alberto/cardano/preview/ipc,target=/opt/cardano/ipc,type=bind"
  ],
  
  "containerEnv": {
    "CARDANO_NODE_SOCKET_PATH": "/opt/cardano/ipc/node.socket"
  },

  "workspaceFolder": "/workspaces/cardano-cloud",
  "overrideCommand": true, // Esto equivale al 'sleep infinity' para que no se cierre



  "postStartCommand": "BASE=https://book.world.dev.cardano.org/environments/preview && mkdir -p /config && for f in config.json topology.json byron-genesis.json shelley-genesis.json alonzo-genesis.json conway-genesis.json checkpoints.json; do [ -f /config/$f ] || curl -sSL $BASE/$f -o /config/$f; done && nohup /root/cardano-node/dist-newstyle/build/x86_64-linux/ghc-9.6.6/cardano-node-10.6.1/x/cardano-node/build/cardano-node/cardano-node run --config /config/config.json --topology /config/topology.json --database-path /data/db/db --socket-path /opt/cardano/ipc/node.socket --host-addr 0.0.0.0 --port 3001 > /var/log/cardano-node.log 2>&1 &",

  "forwardPorts": [3001]

}
